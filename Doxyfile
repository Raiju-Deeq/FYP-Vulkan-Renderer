# Doxyfile for FYP Vulkan Renderer
# Minimal, focused configuration generated by assistant.

DOXYFILE_ENCODING      = UTF-8

PROJECT_NAME           = "FYP Vulkan Renderer"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "Final year project: Vulkan 1.3 renderer"

# Output inside the docs directory.
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO

# Use English for all UI strings
OUTPUT_LANGUAGE        = English

# Paths and input
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .

INPUT                  = README.md src docs/dev-log
RECURSIVE              = YES

EXCLUDE_PATTERNS       = */build/*                          */cmake-build-*/*                          */docs/doxygen/*                          */external/*                          */third_party/*                          */vcpkg_installed/*

FILE_PATTERNS          = *.h                          *.hpp                          *.c                          *.cc                          *.cpp                          *.ixx                          *.ipp                          *.inl                          *.md

# Documentation extraction behaviour
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_UNDOC_NAMESPACES  = YES

# Use README.md as the main page if present
USE_MDFILE_AS_MAINPAGE = README.md
IMPLICIT_DIR_DOCS      = YES

# Warnings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_NO_PARAMDOC       = NO

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES

# Indexing and layout
ALPHABETICAL_INDEX     = YES
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST= YES

# HTML output only – disable LaTeX / others for faster runs
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_DOCSET        = NO
GENERATE_XML           = NO
GENERATE_QHP           = NO
GENERATE_ECLIPSEHELP   = NO

# HTML look & feel
HTML_COLORSTYLE        = AUTO_LIGHT
GENERATE_TREEVIEW      = YES
PAGE_OUTLINE_PANEL     = YES
FULL_SIDEBAR           = YES
HTML_DYNAMIC_SECTIONS  = YES
HTML_CODE_FOLDING      = YES
HTML_COPY_CLIPBOARD    = YES

# Diagrams (requires Graphviz / dot installed)
HAVE_DOT               = NO
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
# CLASS_DIAGRAMS is obsolete in newer Doxygen, so leave it out to avoid warnings
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_MULTI_TARGETS      = YES
