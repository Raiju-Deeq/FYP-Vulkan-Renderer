[
  // ── Linux (Home — Arch) ───────────────────────────────────────────────────
  {
    "label": "[Linux] CMake: Configure (linux-debug)",
    "command": "cmake --preset linux-debug",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["cmake"]
  },
  {
    "label": "[Linux] CMake: Configure (linux-release)",
    "command": "cmake --preset linux-release",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["cmake"]
  },
  {
    "label": "[Linux] Build: Debug",
    "command": "cmake --build --preset linux-debug",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build"]
  },
  {
    "label": "[Linux] Build: Release",
    "command": "cmake --build --preset linux-release",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build"]
  },
  {
    "label": "[Linux] Build: Shaders only",
    "command": "cmake --build --preset linux-debug --target shaders",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build"]
  },
  {
    "label": "[Linux] Build: Docs (Doxygen)",
    "command": "cmake --build --preset linux-debug --target docs",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["docs"]
  },
  {
    "label": "[Linux] Run: Debug",
    "command": "./build/linux-debug/vulkan-renderer",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["run"]
  },
  {
    "label": "[Linux] Run: Debug + Validation Layers",
    "command": "VK_INSTANCE_LAYERS=VK_LAYER_KHRONOS_validation ./build/linux-debug/vulkan-renderer",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["run"]
  },
  {
    "label": "[Linux] Run: Release",
    "command": "./build/linux-release/vulkan-renderer",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["run"]
  },
  {
    "label": "[Linux] Build & Run: Debug + Validation Layers",
    "command": "cmake --build --preset linux-debug && VK_INSTANCE_LAYERS=VK_LAYER_KHRONOS_validation ./build/linux-debug/vulkan-renderer",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build", "run"]
  },

  // ── Windows (DMU Lab — Visual Studio 2022) ────────────────────────────────
  // These tasks use uni-* presets, so CMake only enables them on Windows.
  // VS generator places the binary at build/uni-debug/Debug/vulkan-renderer.exe
  {
    "label": "[Uni] CMake: Configure (uni-debug)",
    "command": "cmake --preset uni-debug",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["cmake"]
  },
  {
    "label": "[Uni] CMake: Configure (uni-release)",
    "command": "cmake --preset uni-release",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["cmake"]
  },
  {
    "label": "[Uni] Build: Debug",
    "command": "cmake --build --preset uni-debug",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build"]
  },
  {
    "label": "[Uni] Build: Release",
    "command": "cmake --build --preset uni-release",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build"]
  },
  {
    "label": "[Uni] Build: Shaders only",
    "command": "cmake --build --preset uni-debug --target shaders",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build"]
  },
  {
    "label": "[Uni] Build: Docs (Doxygen)",
    "command": "cmake --build --preset uni-debug --target docs",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["docs"]
  },
  {
    "label": "[Uni] Run: Debug",
    "command": "build/uni-debug/Debug/vulkan-renderer.exe",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["run"]
  },
  {
    "label": "[Uni] Run: Debug + Validation Layers",
    "command": "build/uni-debug/Debug/vulkan-renderer.exe",
    "env": { "VK_INSTANCE_LAYERS": "VK_LAYER_KHRONOS_validation" },
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["run"]
  },
  {
    "label": "[Uni] Run: Release",
    "command": "build/uni-release/Release/vulkan-renderer.exe",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["run"]
  },
  {
    "label": "[Uni] Build & Run: Debug + Validation Layers",
    "command": "cmake --build --preset uni-debug && build/uni-debug/Debug/vulkan-renderer.exe",
    "env": { "VK_INSTANCE_LAYERS": "VK_LAYER_KHRONOS_validation" },
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build", "run"]
  }
]
